# ---------------------------------------------------------------------------
# DealRadar Environment Variables Template
# Copy this file to .env and fill in your credentials.
# Do NOT commit your active .env file to public repositories!
# ---------------------------------------------------------------------------

# 1. Core LLM Configuration (Required)
# Retrieve your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001  # Optional: defaults to claude-opus-4-5 if empty
LLM_BASE_URL=                         # Optional: base URL override for custom proxies

# 2. Intelligence Sources API Keys (Optional fallbacks exist)
# News API (https://newsapi.org/) - Falls back to Google News RSS
NEWS_API_KEY=

# BuiltWith API (https://api.builtwith.com/) - Falls back to HTML pattern scanning
BUILTWITH_API_KEY=

# LinkdAPI (https://linkdapi.com/) - Falls back to graceful empty state
LINKDAPI_API_KEY=
